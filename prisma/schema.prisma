generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id   Int     @id @default(autoincrement())
  nom  RoleNom @unique
  user User[]
}

model User {
  // 🔐 Champs Better Auth (obligatoires)
  id            String   @id @default(cuid())
  name          String
  email         String   @unique @db.VarChar(255)
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 🧑‍💼 Champs métier (ex-`Utilisateur`)
  prenom          String?
  telephone       String?  @unique
  dateInscription DateTime @default(now())

  // 🔗 Rôle (relation vers Role)
  roleId Int?
  role   Role? @relation(fields: [roleId], references: [id])

  // 🔗 Relations métier
  devis         Devis[]
  paiements     Paiement[]
  avis          Avis[]
  favoris       Favori[]
  notifications Notification[]

  // 🔗 Relations Better Auth
  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Theme {
  id       Int       @id @default(autoincrement())
  nom      String    @unique
  circuits Circuit[]
}

model Region {
  id       Int       @id @default(autoincrement())
  nom      String    @unique
  circuits Circuit[]
}

model Circuit {
  id                  Int            @id @default(autoincrement())
  titre               String
  slug                String         @unique
  description         String?
  dureeJours          Int?
  prixEstime          Decimal?       @db.Decimal(10, 2)
  nbPlacesDisponibles Int            @default(0)
  dateDebut           DateTime?
  estGroupe           Boolean        @default(false)
  themeId             Int?
  regionId            Int?
  avis                Avis[]
  region              Region?        @relation(fields: [regionId], references: [id])
  theme               Theme?         @relation(fields: [themeId], references: [id])
  devis               Devis[]
  etapes              Etape[]
  favoris             Favori[]
  images              ImageCircuit[]
}

model ImageCircuit {
  id        Int     @id @default(autoincrement())
  url       String
  legende   String?
  ordre     Int?
  circuitId Int
  circuit   Circuit @relation(fields: [circuitId], references: [id], onDelete: Cascade)
}

model Hebergement {
  id      Int     @id @default(autoincrement())
  nom     String
  type    String?
  etoiles Int?
  adresse String?
  etape   Etape?
}

model Etape {
  id            Int         @id @default(autoincrement())
  ordre         Int
  ville         String?
  description   String?
  circuitId     Int
  hebergementId Int         @unique
  activites     Activite[]
  circuit       Circuit     @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  hebergement   Hebergement @relation(fields: [hebergementId], references: [id])
}

model Activite {
  id          Int      @id @default(autoincrement())
  nom         String
  description String?
  duree       Int?
  prix        Decimal? @db.Decimal(10, 2)
  etapeId     Int
  etape       Etape    @relation(fields: [etapeId], references: [id], onDelete: Cascade)
}

model Devis {
  id                    Int          @id @default(autoincrement())
  dateDemande           DateTime     @default(now())
  nombrePersonnes       Int          @default(1)
  commentaireClient     String?
  commentaireConseiller String?
  montantTotal          Decimal?     @db.Decimal(10, 2)
  statut                StatutDevis  @default(en_cours)
  userId                String
  circuitId             Int?
  circuit               Circuit?     @relation(fields: [circuitId], references: [id])
  user                  User         @relation(fields: [userId], references: [id])
  reservation           Reservation?
}

model Reservation {
  id              Int               @id @default(autoincrement())
  dateReservation DateTime          @default(now())
  montantFinal    Decimal?          @db.Decimal(10, 2)
  statut          StatutReservation @default(confirmee)
  devisId         Int               @unique
  paiement        Paiement?
  devis           Devis             @relation(fields: [devisId], references: [id], onDelete: Cascade)
}

model ModePaiement {
  id        Int        @id @default(autoincrement())
  nom       String     @unique
  paiements Paiement[]
}

model Paiement {
  id                   Int          @id @default(autoincrement())
  montant              Decimal      @db.Decimal(10, 2)
  datePaiement         DateTime     @default(now())
  referenceTransaction String?      @unique
  reservationId        Int?         @unique
  userId               String
  modeId               Int
  mode                 ModePaiement @relation(fields: [modeId], references: [id])
  reservation          Reservation? @relation(fields: [reservationId], references: [id])
  user                 User         @relation(fields: [userId], references: [id])
}

model Avis {
  id          Int      @id @default(autoincrement())
  note        Int
  commentaire String?
  dateAvis    DateTime @default(now())
  estModere   Boolean  @default(false)
  userId      String
  circuitId   Int
  circuit     Circuit  @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
}

model Favori {
  id        Int      @id @default(autoincrement())
  dateAjout DateTime @default(now())
  userId    String
  circuitId Int
  circuit   Circuit  @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, circuitId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  titre     String
  message   String?
  dateEnvoi DateTime @default(now())
  lu        Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

enum RoleNom {
  client
  conseiller
  admin
}

enum StatutDevis {
  en_cours
  en_modification
  valide
  accepte
  refuse
  reserve
}

enum StatutReservation {
  confirmee
  annulee
  terminee
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
